# Netlify / production settings
# Copy these values into Netlify Site settings > Environment variables.

APP_NAME=HRD Drive

# MinIO endpoint must point to your actual MinIO server, not the Netlify site itself.
# Example:
# MINIO_ENDPOINT_URL=https://minio.domainkamu.com
MINIO_ENDPOINT_URL=https://minio.domainkamu.com

MINIO_BUCKET=storage
MINIO_ACCESS_KEY=miniohrd
MINIO_SECRET_KEY=hrdadmin

# Optional basic auth for the web app
# APP_USERNAME=admin
# APP_PASSWORD=your-strong-password

# Optional upload limit in bytes
MAX_UPLOAD_SIZE_BYTES=52428800

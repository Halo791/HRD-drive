APP_NAME=MinIO Storage
PORT=3000

# Local mode for development on your machine.
# Set STORAGE_DRIVER=minio when connecting to an external/public MinIO.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=local-storage

MINIO_ENDPOINT_URL=http://127.0.0.1:9000
MINIO_BUCKET=storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Optional authentication for the web app when exposed online
# APP_USERNAME=admin
# APP_PASSWORD=change-this-password

# Optional: limit uploads in bytes
MAX_UPLOAD_SIZE_BYTES=52428800
